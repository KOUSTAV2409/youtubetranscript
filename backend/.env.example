# Local
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
CORS_ORIGINS=http://localhost:5173
DATABASE_PATH=data/cache.db

# Production (Render dashboard)
# OPENAI_API_KEY=sk-...
# CORS_ORIGINS=*   # or https://your-app.vercel.app
# DATABASE_PATH=/app/data/cache.db

# --- Proxies (optional) ---
# YouTube blocks cloud + most free/datacenter proxies.
# Free/any HTTP proxy (comma-separated = try in order):
# YOUTUBE_PROXY_URL=http://1.2.3.4:8080,http://user:pass@host:3128
#
# Paid residential (most reliable for auto-fetch on Render):
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
